{
  "name": "@feedback/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/client.js",
  "types": "./dist/client.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "db:generate": "set -a && . ../../.env && set +a && prisma generate",
    "db:migrate:dev": "set -a && . ../../.env && set +a && prisma migrate dev",
    "db:migrate:deploy": "set -a && . ../../.env && set +a && prisma migrate deploy",
    "db:studio": "set -a && . ../../.env && set +a && prisma studio",
    "db:seed": "set -a && . ../../.env && set +a && tsx seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prisma": "^5.22.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
